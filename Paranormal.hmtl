<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Menu Bootstrap</title>
    <!-- Passo 3: CDN do Bootstrap -->
    <link href="https://jsdelivr.net" rel="stylesheet">
</head>
<body>

    <!-- Passo 4, 8 e Desafio 5: Barra de navegação responsiva e centralizada -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark"> 
        <div class="container">
            <!-- Passo 5: Marca do site -->
            <a class="navbar-brand" href="#">MinhaMarca</a>

            <!-- Botão para mobile (hambúrguer) -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Passo 6 e 7: Lista de itens -->
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto"> <!-- me-auto joga o resto para a direita -->
                    <li class="nav-item">
                        <a class="nav-link active" href="#">Início</a> <!-- Desafio 2: Active -->
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Sobre</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Serviços</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Contato</a>
                    </li>
                    <!-- Desafio 1: Item Blog -->
                    <li class="nav-item">
                        <a class="nav-link" href="#">Blog</a>
                    </li>
                </ul>
                
                <!-- Desafio 4: Botão Entrar no lado direito -->
                <button class="btn btn-outline-light" type="button">Entrar</button>
            </div>
        </div>
    </nav>

    <script src="https://jsdelivr.net"></script>
</body>
</html>
